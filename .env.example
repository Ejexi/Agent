# ================================================
# DuckOps Agent — Environment Variables
# ================================================
# Copy this file to .env and fill in your values.
# ================================================

# ── DuckOps Server ───────────────────────────────
DUCKOPS_SERVER_URL=https://api.duckops.io
DUCKOPS_API_KEY=your-api-key-here

# ── LLM Providers (at least one required) ────────
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# ── Local LLM (optional) ─────────────────────────
LMSTUDIO_API_KEY=lm-studio
